{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/overtime-evidence-kit/evidence-package.schema.json",
  "title": "EvidencePackage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packageId",
    "periodStart",
    "periodEnd",
    "subjectRole",
    "inputSources",
    "events",
    "evidenceItems",
    "excludedCandidates",
    "validationReports",
    "publicOutputs"
  ],
  "properties": {
    "packageId": { "type": "string", "pattern": "^pkg-[a-z0-9-]+$" },
    "periodStart": { "type": "string", "format": "date" },
    "periodEnd": { "type": "string", "format": "date" },
    "subjectRole": { "type": "string", "minLength": 1 },
    "inputSources": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "./overtime-event.schema.json" }
    },
    "evidenceItems": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "./evidence-item.schema.json" }
    },
    "excludedCandidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidateId", "reason"],
        "properties": {
          "candidateId": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validationReports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["checkName", "status", "message"],
        "properties": {
          "checkName": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "warning", "fail"] },
          "message": { "type": "string" }
        }
      }
    },
    "publicOutputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summaryMarkdown", "evidenceIndexCsv"],
      "properties": {
        "summaryMarkdown": { "type": "string" },
        "evidenceIndexCsv": { "type": "string" }
      }
    }
  }
}

