{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/overtime-evidence-kit/evidence-item.schema.json",
  "title": "EvidenceItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidenceId",
    "eventId",
    "sourceType",
    "sourceFileName",
    "sourceRowNum",
    "messageId",
    "timestamp",
    "senderRole",
    "sourceQuote",
    "quickLocator",
    "redactionLevel"
  ],
  "properties": {
    "evidenceId": { "type": "string", "pattern": "^evd-[a-z0-9-]+$" },
    "eventId": { "type": "string", "pattern": "^evt-[a-z0-9-]+$" },
    "sourceType": {
      "type": "string",
      "enum": ["wechat", "group_chat", "git", "audio_summary", "system_screenshot", "manual_note"]
    },
    "sourceFileName": { "type": "string", "minLength": 1 },
    "sourceRowNum": { "type": "integer", "minimum": 1 },
    "messageId": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "senderRole": { "type": "string", "minLength": 1 },
    "sourceQuote": { "type": "string", "minLength": 1 },
    "quickLocator": { "type": "string", "minLength": 1 },
    "redactionLevel": { "type": "string", "enum": ["mock", "redacted", "public"] },
    "evidenceRole": {
      "type": "string",
      "enum": [
        "task_source",
        "work_process",
        "work_result",
        "git_output",
        "release_coordination",
        "review_note"
      ]
    }
  }
}
